---
import { getCategoryMeta } from '../lib/categories';

interface Props {
  category: string;
  linked?: boolean;
}

const { category, linked = true } = Astro.props;
const meta = getCategoryMeta(category);
---

{
  linked ? (
    <a
      href={`/category/${category}`}
      class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border transition-colors hover:border-border-hover"
      style={`color: ${meta.color}; border-color: color-mix(in oklch, ${meta.color} 20%, transparent); background: color-mix(in oklch, ${meta.color} 7%, transparent);`}
    >
      {meta.label}
    </a>
  ) : (
    <span
      class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border"
      style={`color: ${meta.color}; border-color: color-mix(in oklch, ${meta.color} 20%, transparent); background: color-mix(in oklch, ${meta.color} 7%, transparent);`}
    >
      {meta.label}
    </span>
  )
}
