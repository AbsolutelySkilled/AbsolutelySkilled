---
import SearchButton from './SearchButton.astro';
import GitHubBadge from './GitHubBadge.astro';
---

<header class="border-b border-border sticky top-0 bg-page/80 backdrop-blur-xl z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 group shrink-0">
      <img src="/logo.png" alt="AbsolutelySkilled" class="w-7 h-7" />
      <span class="text-lg font-bold font-display text-text-primary group-hover:text-primary-light transition-colors hidden sm:inline">
        AbsolutelySkilled
      </span>
    </a>

    <div class="flex-1 max-w-sm">
      <SearchButton />
    </div>

    <div class="flex items-center gap-5 shrink-0">
      <a href="/skills" class="text-sm text-text-secondary hover:text-text-primary transition-colors hidden sm:block">Skills</a>
      <a href="/agents" class="text-sm text-text-secondary hover:text-text-primary transition-colors hidden sm:block">Agents</a>
      <a href="/blog" class="text-sm text-text-secondary hover:text-text-primary transition-colors hidden sm:block">Blog</a>
      <a
        href="https://github.com/AbsolutelySkilled/AbsolutelySkilled/issues/new?template=skill_request.yml&title=%5BSkill+Request%5D+%3Cskill+name%3E"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-primary-light hover:text-primary transition-colors hidden sm:block"
      >
        Request a Skill
      </a>
      <GitHubBadge />
    </div>
  </nav>
</header>
