---
import { getCategoryMeta } from '../lib/categories';

interface Props {
  categories: { category: string; count: number }[];
}

const { categories } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
  {categories.map(({ category, count }) => {
    const meta = getCategoryMeta(category);
    return (
      <a
        href={`/category/${category}`}
        class="card p-4 group text-center"
      >
        <div class="flex items-center justify-center gap-2 mb-1">
          <span
            class="text-[10px] font-display font-bold tracking-wider px-1.5 py-0.5 rounded"
            style={`color: ${meta.color}; background: color-mix(in oklch, ${meta.color} 10%, transparent);`}
          >
            {meta.icon}
          </span>
        </div>
        <div
          class="text-sm font-bold font-display group-hover:text-primary-light transition-colors"
          style={`color: ${meta.color};`}
        >
          {meta.label}
        </div>
        <div class="text-xs text-text-muted mt-1">{count} skills</div>
      </a>
    );
  })}
</div>
